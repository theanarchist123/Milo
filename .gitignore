# Root-level ignore rules

# Local env files (never commit secrets)
*.env.local
backend/.env.local
frontend/.env.local

# Keep tracked defaults if needed, but ignore private overrides

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Backend artifacts
backend/node_modules/
backend/package-lock.json
backend/miro.db
backend/media/outputs/*
!backend/media/outputs/.gitkeep

# Frontend build output
frontend/dist

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
