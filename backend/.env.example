# Safe template for backend configuration.
# Copy to .env.local for local development and set real values.

# Ollama / LLM settings
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_ENDPOINT=https://ollama.com/v1/chat/completions
OLLAMA_MODEL=deepseek-v3.1:671b

# Local DB (replace with Postgres in production)
DATABASE_URL=sqlite:///./miro.db

# Firebase token verification
FIREBASE_PROJECT_ID=your_firebase_project_id

# Optional CORS settings
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1)(:\d+)?
